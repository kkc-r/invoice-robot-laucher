{
  "name": "launcher",
  "productName": "Launcher",
  "version": "0.0.2",
  "private": true,
  "homepage": "./",
  "main": "build/electron/main.js",
  "author": "test",
  "description": "",
  "repository": {
    "url": "https://github.com/kkc-r/invoice-robot-laucher.git"
  },
  "build": {
    "extends": null,
    "files": [
      "!dist/*",
      "!src/*",
      "!electron/*",
      "!README.md"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "menuCategory": true
    }
  },
  "dependencies": {
    "@emotion/react": "11.10.6",
    "@emotion/styled": "11.10.6",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.12.0",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "13.4.0",
    "@types/jest": "^27.0.1",
    "@types/node": "18.16.1",
    "@types/react": "^18.0.35",
    "@types/react-dom": "^18.0.11",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.26",
    "axios": "^1.3.5",
    "buffer": "^6.0.3",
    "electron-is-dev": "^2.0.0",
    "electron-log": "^4.4.8",
    "electron-reload": "^2.0.0-alpha.1",
    "electron-store": "^8.1.0",
    "electron-updater": "4.6.5",
    "jssha": "^3.3.0",
    "mui-modal-provider": "^2.2.0",
    "normalize.css": "^8.0.1",
    "path-browserify": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.10.0",
    "react-scripts": "5.0.1",
    "styled-components": "^5.3.10",
    "typescript": "^4.4.2",
    "update-electron-app": "^2.0.1",
    "web-vitals": "^2.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron:build": "tsc -p electron && yarn obfuscator",
    "obfuscator": "javascript-obfuscator ./build/electron/main.js --output ./build/electron/main.js",
    "electron:dev": "concurrently \"yarn start\" \"wait-on http://localhost:3000 && tsc -p electron -w\" \"wait-on http://localhost:3000 && tsc -p electron && electron .\"",
    "electron-dev2": "set ELECTRON_START_URL=http://localhost:3000 && electron public",
    "start-electron": "wait-on http://localhost:3000 && electron .",
    "electron:build-win-x64:dev": "yarn build && yarn electron:build && electron-builder",
    "electron:build-win-x64": "set GENERATE_SOURCEMAP=false && yarn build && yarn electron:build && electron-builder",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.0.1",
    "cross-env": "^7.0.3",
    "electron": "^24.1.2",
    "electron-builder": "^23.6.0",
    "javascript-obfuscator": "^4.0.2",
    "wait-on": "^7.0.1"
  },
  "browser": {
    "crypto": false,
    "fs": false
  }
}
